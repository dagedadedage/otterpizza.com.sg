# Database (SQLite for development)
DATABASE_URL="file:./dev.db"

# NextAuth
AUTH_SECRET="change-me-to-a-random-secret"
AUTH_URL="http://localhost:3000"

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID="your_google_client_id"
AUTH_GOOGLE_SECRET="your_google_client_secret"

# Google Auth Whitelist (email -> role mapping, JSON format)
GOOGLE_AUTH_WHITELIST={"admin@otter-group.com":"ADMIN","manager@otter-group.com":"MANAGER"}

# HitPay (sandbox — switch to production for launch)
HITPAY_API_KEY="your_sandbox_api_key"
HITPAY_WEBHOOK_SALT="your_webhook_salt"
HITPAY_BASE_URL="https://api.sandbox.hit-pay.com/v1"

# Email (Resend)
RESEND_API_KEY="your_resend_api_key"
ADMIN_EMAIL="admin@otterpizza.com.sg"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Otter Pizza"

# Google Analytics (GA4 Measurement ID)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
